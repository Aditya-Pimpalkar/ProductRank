# Copy to .env and fill in. .env is git-ignored; never commit real secrets.

# --- OpenAI (embeddings only; the one real secret) ---
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- Postgres (matches docker-compose.yml) ---
POSTGRES_USER=productrank
POSTGRES_PASSWORD=productrank
POSTGRES_DB=productrank
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# --- Redis (host 6380 to avoid colliding with other local Redis on 6379) ---
REDIS_URL=redis://localhost:6380/0

# --- Retrieval / rerank ---
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RRF_K=60
DEFAULT_TOP_K=10
RERANK_CANDIDATES=100
IVFFLAT_LISTS=100
IVFFLAT_PROBES=10

# --- App ---
FRONTEND_ORIGIN=http://localhost:3000
LOG_LEVEL=INFO
